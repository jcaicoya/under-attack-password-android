<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Cuarzito — estado de conexión y show -->
    <ImageView
        android:id="@+id/ivCuarzito"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:src="@drawable/cuarzito_amber"
        android:contentDescription="@null" />

    <!-- Panel inferior — formulario de contraseña -->
    <LinearLayout
        android:id="@+id/formPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/panel_bg"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTRASEÑA DE ACCESO"
            android:textSize="11sp"
            android:textColor="@color/text_dim"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Contraseña"
            android:inputType="textPassword"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_dim"
            android:background="@drawable/field_bg"
            android:paddingHorizontal="16dp"
            android:fontFamily="monospace"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etConfirm"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Repite la contraseña"
            android:inputType="textPassword"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_dim"
            android:background="@drawable/field_bg"
            android:paddingHorizontal="16dp"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF4444"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="GUARDAR CONTRASEÑA"
            android:textColor="#000000"
            android:backgroundTint="@color/amber_accent"
            android:fontFamily="monospace"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <!-- Resultado overlay -->
    <FrameLayout
        android:id="@+id/resultOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EE000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp">

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="28sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/tvResultPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF4444"
                android:textSize="26sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="40dp" />

            <Button
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CONTINUAR"
                android:textColor="#000000"
                android:backgroundTint="@color/amber_accent"
                android:fontFamily="monospace" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
